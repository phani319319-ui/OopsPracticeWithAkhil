<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- bean definitions here -->
    <bean id="sarees" class="org.example.services.Sarees"/>
    <bean id="dresses" class="org.example.services.Dresses"/>
    <bean id="westernwear" class="org.example.services.Westernwear"/>

    <bean id="seesu" class="org.example.SeesuShop">
        <constructor-arg ref="sarees" name="web"/>
        <property name="web" ref="dresses"/>
    </bean>







</beans>